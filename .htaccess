# Root /iit/ rewrite-only rules (no authentication here).
# Friendly lab URLs used in the Lab 10 rubric/instructions.

RewriteEngine On

RewriteRule ^lab01/?$ /iit/labs/lab03/lab03b/lab01_landing.html [R=302,L]
RewriteRule ^lab02/?$ /iit/labs/lab03/lab03b/lab02_landing.html [R=302,L]
RewriteRule ^lab09/?$ /iit/labs/lab09/ [R=302,L]
RewriteRule ^lab10/?$ /iit/labs/lab10/lab10_landing.html [R=302,L]
